{
  "name": "@coderank/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc --build && tsc-alias",
    "start": "node dist/app.js",
    "typecheck": "tsc --noEmit",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@coderank/types": "workspace:*",
    "@fastify/cookie": "^9.3.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@types/bcrypt": "^5.0.2",
    "@types/dockerode": "^3.3.29",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.8.0",
    "dockerode": "^4.0.2",
    "drizzle-orm": "^0.30.10",
    "fastify": "^4.28.0",
    "ioredis": "^5.3.2",
    "nanoid": "^5.0.7",
    "pg": "^8.12.0",
    "dotenv": "^16.4.5",
    "tsc-alias": "^1.8.10",
    "typescript": "^5.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "drizzle-kit": "^0.21.4",
    "tsx": "^4.15.0"
  }
}
